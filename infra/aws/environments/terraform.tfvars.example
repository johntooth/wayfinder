# Copy to terraform.tfvars and adjust. These are the *shared* stamp settings;
# per-environment values (name, semchunk, image tags) are usually passed by
# scripts/new-environment.sh via -var flags.

aws_region   = "eu-west-2"
state_bucket = "<your-terraform-state-bucket>"

# Optional: hosted zone for automatic <env>.<base_domain> DNS records.
# route53_zone_id = "Z0123456789ABC"

# Defaults every stamped environment inherits unless overridden per apply.
# web_image_tag       = "latest"
# ai_default_provider = "anthropic"
